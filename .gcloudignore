# Cloud Build context: exclude unneeded files.
# When deploying, use AgenticAI_Backend/.../NautiCAI_Backend/ as context.
.git/
.gitignore
node_modules/
.next/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.idea/
.vscode/
.DS_Store
*.log
.env
.env.*
!.env.example
frontend/
css/
js/
*.html
image.png
# Model weights (large; add in backend folder at deploy or via env)
*.pt
*.pth
sam_checkpoints/

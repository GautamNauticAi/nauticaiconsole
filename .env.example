# Copy to .env and fill in values. NautiCAI repo root (folder that contains openclaw/).

# --- Database (Agentic backend auth) ---
# POSTGRES_DSN=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- OpenClaw: auto-inspect when files appear in a folder ---
# Run backend first, then: python3 openclaw/watcher.py (from this repo root)
BACKEND_URL=http://127.0.0.1:8000
# JWT from the web app after login (Application → Local Storage → nauticai:token) or signup/login API
OPENCLAW_API_TOKEN=
# Folder to watch (create it if needed). Default if unset: <repo>/incoming
# Linux: OPENCLAW_INCOMING_DIR=/home/you/Downloads/check
# Windows (use forward slashes): OPENCLAW_INCOMING_DIR=C:/Users/You/Downloads/Check
# OPENCLAW_PROCESSED_DIR=
# OPENCLAW_FAILED_DIR=
# OPENCLAW_HEALTH_URL=/health

# --- Optional: same as backend Telegram ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Frontend / email (if used) ---
# FRONTEND_URL=http://localhost:3000
# BREVO_SMTP_USER=
# BREVO_SMTP_KEY=
